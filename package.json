{
  "name": "angular2",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:connected": "ng build --configuration production,connected",
    "build:github-pages": "node scripts/build-github-pages.mjs",
    "build:server": "ng build --configuration server",
    "e2e:serve": "node scripts/serve-static.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test --watch=false --include src/**/*.unit.spec.ts",
    "test:integration": "ng test --watch=false --include src/app/app.integration.spec.ts --include src/app/features/contact/contact.page.integration.spec.ts",
    "test:e2e": "playwright test",
    "test:ci": "npm run test:unit && npm run test:integration && npm run build && npm run test:e2e",
    "serve:ssr": "node dist/angular2/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
